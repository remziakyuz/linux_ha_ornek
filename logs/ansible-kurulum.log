2026-03-24 09:54:45,974 p=280047 u=root n=ansible | TASK [SETUP | /etc/hosts - Loopback çakışmasını temizle _raw_params={% for host in groups['cluster_nodes'] + groups['quorum_device'] %}
SHORT="{{ host.split('.')[0] }}"
FQDN="{{ host }}"
sed -i "/^::1[[:space:]]/ s/\b${SHORT}\b//g; /^::1[[:space:]]/ s/\b${FQDN}\b//g" /etc/hosts
sed -i "/^127\.[0-9]*\.[0-9]*\.[0-9]*[[:space:]]/ s/\b${SHORT}\b//g; /^127\.[0-9]*\.[0-9]*\.[0-9]*[[:space:]]/ s/\b${FQDN}\b//g" /etc/hosts
{% endfor %}
# Boş kalan loopback satırlarını derle (sadece "::1" veya "127.x.x.x" kalan satırlar)
sed -i '/^::1[[:space:]]*$/d' /etc/hosts
sed -i '/^127\.[0-9]*\.[0-9]*\.[0-9]*[[:space:]]*$/d' /etc/hosts
] ***
