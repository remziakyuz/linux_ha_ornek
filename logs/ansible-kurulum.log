2026-03-24 10:02:29,895 p=280047 u=root n=ansible | TASK [WEB | index.php test sayfası oluştur dest={{ nginx_web_root | default(gfs2_mount + '/html') }}/index.php, content=<?php
// HA Cluster PHP Test Sayfası
$cluster_name  = "{{ cluster_name }}";
$virtual_ip    = "{{ virtual_ip }}";
$web_root      = "{{ nginx_web_root | default(gfs2_mount + '/html') }}";
$gfs2_mount    = "{{ gfs2_mount }}";
$node_hostname = gethostname();
$node_ip       = $_SERVER['SERVER_ADDR'] ?? '?';
$php_version   = PHP_VERSION;
$php_fpm_ok    = (php_sapi_name() === 'fpm-fcgi');

// GFS2 erişim testi — web kök altında yaz (nginx kullanıcısının izni var)
// NOT: $gfs2_mount kök dizinine değil $web_root/tmp/ altına yazılır.
// nginx kullanıcısı /shared/webfs/html/ dizininde okuma/yazma yetkisine sahip.
$test_dir   = $web_root . '/tmp';
$test_file  = $test_dir . '/.ha_test_' . $node_hostname;
if (!is_dir($test_dir)) @mkdir($test_dir, 0755, true);
$gfs2_write = @file_put_contents($test_file, date('Y-m-d H:i:s') . ' ' . $node_hostname) !== false;
if (file_exists($test_file)) @unlink($test_file);

// PostgreSQL bağlantı testi — pg_connect (php-pgsql) veya PDO fallback
$pgsql_ok  = false;
$pgsql_msg = '';
$pgsql_ext = '';

if (function_exists('pg_connect')) {
    // php-pgsql native driver
    $pgsql_ext = 'pg_connect (php-pgsql)';
    $conn = @pg_connect("host={{ virtual_ip }} port={{ pgsql_port }} dbname=postgres user=postgres password={{ pgsql_password }} connect_timeout=3");
    if ($conn) {
        $pgsql_ok  = true;
        $ver = pg_version($conn);
        $pgsql_msg = 'Bağlantı başarılı — PostgreSQL ' . ($ver['server'] ?? '?');
        pg_close($conn);
    } else {
        $pgsql_msg = 'Bağlantı başarısız — pg_hba.conf veya parola kontrol edin';
    }
} elseif (class_exists('PDO') && in_array('pgsql', PDO::getAvailableDrivers())) {
    // PDO pgsql fallback
    $pgsql_ext = 'PDO::pgsql';
    try {
        $dsn  = "pgsql:host={{ virtual_ip }};port={{ pgsql_port }};dbname=postgres;connect_timeout=3";
        $pdo  = new PDO($dsn, 'postgres', '{{ pgsql_password }}');
        $stmt = $pdo->query('SELECT version()');
        $row  = $stmt->fetch(PDO::FETCH_NUM);
        $pgsql_ok  = true;
        $pgsql_msg = 'Bağlantı başarılı — ' . substr($row[0] ?? 'PostgreSQL', 0, 40);
    } catch (PDOException $e) {
        $pgsql_msg = 'Bağlantı başarısız — ' . $e->getMessage();
    }
} else {
    $pgsql_ext = 'yok';
    $pgsql_msg = 'php-pgsql veya PDO pgsql sürücüsü kurulu değil';
}

function status_badge($ok, $yes = 'OK', $no = 'HATA') {
    $color = $ok ? '#22c55e' : '#ef4444';
    $text  = $ok ? $yes : $no;
    return "<span style=\"background:$color;color:#fff;padding:3px 10px;border-radius:12px;font-size:0.75rem;font-weight:600;\">$text</span>";
}
?>
