# =========================================================
# GFS2 I/O Saglik Denetcisi — ocf:heartbeat:gfs2_health
# Her monitor cagrisinda GFS2 uzerinde gercek yazma testi
# yapar. Basarisiz olursa on-fail=fence ile node fence edilir.
# =========================================================
: ${OCF_FUNCTIONS_DIR=${OCF_ROOT}/lib/heartbeat}
. ${OCF_FUNCTIONS_DIR}/ocf-shellfuncs

MOUNTPOINT="${OCF_RESKEY_mountpoint:-/shared/webfs}"
IO_TIMEOUT="${OCF_RESKEY_io_timeout:-8}"
HOSTNAME_SHORT=$(hostname -s)
TESTFILE="${MOUNTPOINT}/.pacemaker_health_${HOSTNAME_SHORT}"

gfs2_health_meta_data() {
    cat <<XML
<?xml version="1.0"?>
<!DOCTYPE resource-agent SYSTEM "ra-api-1.dtd">
<resource-agent name="gfs2_health" version="1.0">
  <shortdesc lang="en">GFS2 I/O health monitor</shortdesc>
  <longdesc lang="en">
    Performs periodic write/delete I/O test on GFS2 mount point.
    on-fail=fence ensures automatic recovery on I/O errors.
  </longdesc>
  <parameters>
    <parameter name="mountpoint" unique="0" required="0">
      <shortdesc lang="en">GFS2 mount point to test</shortdesc>
      <content type="string" default="/shared/webfs"/>
    </parameter>
    <parameter name="io_timeout" unique="0" required="0">
      <shortdesc lang="en">I/O operation timeout in seconds</shortdesc>
      <content type="integer" default="8"/>
    </parameter>
  </parameters>
  <actions>
    <action name="start"        timeout="20s"/>
    <action name="stop"         timeout="20s"/>
    <action name="monitor"      timeout="20s" interval="15s" depth="0"/>
    <action name="validate-all" timeout="5s"/>
    <action name="meta-data"    timeout="5s"/>
  </actions>
</resource-agent>
XML
    return $OCF_SUCCESS
}

gfs2_health_validate() {
    if [ ! -d "${MOUNTPOINT}" ]; then
        ocf_log err "Mount noktasi dizin degil: ${MOUNTPOINT}"
        return $OCF_ERR_CONFIGURED
    fi
    return $OCF_SUCCESS
}

gfs2_health_start() {
    gfs2_health_monitor
}

gfs2_health_stop() {
    rm -f "${TESTFILE}" 2>/dev/null
    return $OCF_SUCCESS
}

gfs2_health_monitor() {
    # Mount kontrol
    if ! mountpoint -q "${MOUNTPOINT}" 2>/dev/null; then
        ocf_log err "GFS2 mount degil: ${MOUNTPOINT}"
        return $OCF_NOT_RUNNING
    fi

    # GFS2 withdraw kontrol (errors=withdraw ile)
    local gfs2_flags=""
    local fs_name=$(basename "${MOUNTPOINT}")
    if [ -f "/sys/kernel/debug/gfs2/${fs_name}.0/flags" ]; then
        gfs2_flags=$(cat "/sys/kernel/debug/gfs2/${fs_name}.0/flags" 2>/dev/null || echo "")
        if echo "${gfs2_flags}" | grep -q "withdrawn"; then
            ocf_log err "GFS2 withdrawn durumunda: ${MOUNTPOINT}"
            return $OCF_ERR_GENERIC
        fi
    fi

    # Gercek I/O testi: yaz
    if ! timeout "${IO_TIMEOUT}" bash -c "echo \$\$ > '${TESTFILE}'" 2>/dev/null; then
        ocf_log err "GFS2 YAZMA HATASI (I/O error/withdraw): ${TESTFILE}"
        rm -f "${TESTFILE}" 2>/dev/null
        return $OCF_ERR_GENERIC
    fi

    # Gercek I/O testi: sil
    if ! timeout "${IO_TIMEOUT}" rm -f "${TESTFILE}" 2>/dev/null; then
        ocf_log warn "GFS2 silme hatasi (kritik degil): ${TESTFILE}"
    fi

    return $OCF_SUCCESS
}

case "${__OCF_ACTION}" in
    meta-data)      gfs2_health_meta_data ;;
    start)          gfs2_health_start ;;
    stop)           gfs2_health_stop ;;
    monitor)        gfs2_health_monitor ;;
    validate-all)   gfs2_health_validate ;;
    *)
        ocf_log err "Bilinmeyen OCF eylemi: ${__OCF_ACTION}"
        exit $OCF_ERR_UNIMPLEMENTED
        ;;
esac
] ***
