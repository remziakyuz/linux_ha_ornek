2026-03-24 09:57:08,227 p=280047 u=root n=ansible | TASK [redhat.rhel_system_roles.ha_cluster : Create a corosync.conf file content using pcs-0.10 _raw_params=pcs cluster setup --corosync_conf {{ __ha_cluster_tempfile_corosync_conf.path | quote }} --overwrite {% if "cluster.config.uuid" in __ha_cluster_pcs_capabilities %}
  --no-cluster-uuid
