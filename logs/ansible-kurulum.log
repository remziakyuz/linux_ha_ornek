2026-03-24 09:54:53,987 p=280047 u=root n=ansible | TASK [RESILIENCE | Kernel sysctl - GFS2 I/O takılma koruması dest=/etc/sysctl.d/10-ha-cluster-resilience.conf, content=# HA Cluster GFS2/iSCSI dayanıklılık ayarları
# Ansible tarafından yönetilir — ha_cluster_setup.yml

# ---- HUNG TASK PANIC ------------------------------------------------
# GFS2 I/O takıldığında (iSCSI path down → GFS2 withdraw) kernel
# belirlenen süre sonra panic yaparak node'u fence eder.
# STONITH devreye girer → node reboot → iSCSI yeniden bağlanır → GFS2 temiz açılır.
#
# hung_task_timeout_secs: Bu süre I/O bekleyen task → "hung task" sayılır (s)
# hung_task_panic: Hung task tespit edilince kernel panic yap (0=disable, 1=enable)
kernel.hung_task_timeout_secs = 120
kernel.hung_task_panic = 1

# ---- KERNEL PANIC REBOOT ------------------------------------------
# Kernel panic sonrası kaç saniye bekleyip reboot edilsin
# 0 = hemen, 30 = 30 saniye (IPMI konsol erişimi için)
kernel.panic = 30

# ---- PANIC ON OOPS ------------------------------------------------
# Kernel oops (non-fatal bug) de panic'e dönüştür
kernel.panic_on_oops = 1

# ---- NFS/GFS2 SOFT LOCKUP ------------------------------------------
# Soft lockup watchdog timeout (saniye)
kernel.watchdog_thresh = 30
, mode=0644, owner=root, group=root] ***
