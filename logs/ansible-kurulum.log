2026-03-24 09:54:56,686 p=280047 u=root n=ansible | TASK [RESILIENCE | GFS2 probe script oluştur dest=/usr/local/sbin/gfs2-probe.sh, content=#!/bin/bash
# GFS2 Gerçek I/O Probe Script
# Pacemaker gfs2_probe kaynağı tarafından kullanılır
# /shared/webfs üzerine gerçek yazma/okuma testi yapar
# GFS2 withdraw → I/O error → Pacemaker on-fail=fence devreye girer
#
# OCF exit kodları:
#   0  = OCF_SUCCESS    (GFS2 sağlıklı)
#   1  = OCF_ERR_GENERIC (GFS2 erişilemiyor → fence)
#   7  = OCF_NOT_RUNNING (mount edilmemiş — fence değil, sadece dur)

GFS2_MOUNT="${OCF_RESKEY_mountpoint:-/shared/webfs}"
PROBE_FILE="${GFS2_MOUNT}/.pacemaker_gfs2_probe_$(hostname -s)"
TIMEOUT="${OCF_RESKEY_timeout:-10}"

# Mount kontrol
if ! mountpoint -q "${GFS2_MOUNT}" 2>/dev/null; then
  echo "GFS2 probe: ${GFS2_MOUNT} mount edilmemiş"
  exit 7
fi

# Gerçek I/O testi: yazma + okuma + silme (timeout ile)
RESULT=$(timeout "${TIMEOUT}" bash -c "
  echo \$(date +%s%N)-\$(hostname -s) > '${PROBE_FILE}' 2>&1
  RC=\$?
  if [ \$RC -eq 0 ]; then
    cat '${PROBE_FILE}' > /dev/null 2>&1 && RC=\$? || RC=\$?
    rm -f '${PROBE_FILE}' 2>/dev/null
  fi
  exit \$RC
" 2>&1)
RC=$?

if [ $RC -eq 0 ]; then
  echo "GFS2 probe: ${GFS2_MOUNT} I/O OK"
  exit 0
elif [ $RC -eq 124 ]; then
  echo "GFS2 probe: ${GFS2_MOUNT} I/O TIMEOUT (${TIMEOUT}s) — GFS2 withdraw olabilir!"
  exit 1
else
  echo "GFS2 probe: ${GFS2_MOUNT} I/O ERROR (rc=${RC}) — ${RESULT}"
  exit 1
fi
