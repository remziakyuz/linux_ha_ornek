2026-03-24 09:56:28,088 p=280047 u=root n=ansible | TASK [MULTIPATH | /etc/multipath.conf - inventory WWID alias tanımları dest=/etc/multipath.conf, content=# Ansible tarafından yönetilir — hosts.yml → multipath_aliases
# WWID ve alias değişikliği için hosts.yml güncelleyin.
#
# HIZLI PATH FAILURE DETECTION:
#   polling_interval 2  : Path sağlığı her 2s kontrol edilir (default: 5s)
#   path_checker readsector0 : Gerçek disk okuması ile path sağlığı test edilir
#   fast_io_fail_tmo 5  : iSCSI bağlantısı kaybolunca 5s sonra I/O hata ver (default: 30s)
#   no_path_retry 3     : 3 başarısız deneme sonra I/O hata döndür (default: queue)
#   failback immediate  : Path geri gelince hemen kullanmaya başla
defaults {
    user_friendly_names  no
    find_multipaths      yes
    enable_foreign       "^$"
    polling_interval     2
    path_checker         readsector0
    path_selector        "round-robin 0"
    path_grouping_policy multibus
    failback             immediate
    no_path_retry        3
    fast_io_fail_tmo     5
    dev_loss_tmo         10
    rr_weight            priorities
}
blacklist {
    devnode "^(ram|raw|loop|fd|md|dm-|sr|scd|st)[0-9]*"
    devnode "^hd[a-z]"
    devnode "^vd[a-z]"
}
multipaths {
{% for entry in multipath_aliases %}
    multipath {
        wwid  {{ entry.wwid }}
        alias {{ entry.alias }}
    }
{% endfor %}
}
, mode=0644, owner=root, group=root] ***
